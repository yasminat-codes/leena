# =============================================================
# Leena — Environment Variables (example / reference)
# =============================================================
# Your real .env already exists and is gitignored. This file documents
# ONLY the variables Leena reads. Copy any missing ones into your .env.
# Most are already set in your .env. See SETUP-UNBLOCK.md for what (if
# anything) you need to do before the autonomous build runs.
#
# Leena stores per-user runtime secrets in the macOS keychain via Electron
# safeStorage (entered during onboarding) — these env vars are for
# development/build convenience and CI only.
# -------------------------------------------------------------

# --- AI Providers (runtime) ---------------------------------
# OpenAI — primary provider (chat, embeddings, realtime voice, TTS, STT).
# REQUIRED for voice. Must have Realtime API access (ChatGPT Plus OAuth or
# an API key on a tier with gpt-realtime access).
OPENAI_API_KEY=sk-...

# OpenRouter — optional alternative chat/embeddings provider (200+ models).
# OPTIONAL. Leave blank to disable the OpenRouter provider.
OPENROUTER_API_KEY=sk-or-...

# Ollama — local/offline provider (chat, embeddings, optional TTS/STT).
# OPTIONAL. Defaults to http://localhost:11434 if unset. Requires the
# Ollama app running + models pulled (see SETUP-UNBLOCK.md).
OLLAMA_BASE_URL=http://localhost:11434

# --- Optional integrations ----------------------------------
# Composio — optional MCP/tool bridge (Phase 5). Per-user key entered in
# onboarding; this is the dev fallback.
COMPOSIO_API_KEY=
# Mem0 — optional cloud memory adapter (Phase 3 alternative to local SQLite).
MEM0_API_KEY=

# --- Build / Distribution (developer machine + CI only) -----
# Apple code signing — OPTIONAL. Leena ships UNSIGNED by default (users run
# `xattr -cr /Applications/Leena.app` once). Set these only if you obtain a
# Developer ID cert and want a signed + notarized build.
# CSC_LINK=
# CSC_KEY_PASSWORD=
# APPLE_ID=
# APPLE_ID_PASSWORD=
# APPLE_TEAM_ID=
# When NO cert is present, the build sets:
#   CSC_IDENTITY_AUTO_DISCOVERY=false   (forces clean unsigned build)

# GitHub token — OPTIONAL. Only needed if you publish auto-update releases
# via electron-builder's GitHub provider.
# GH_TOKEN=
