{
  "name": "leena",
  "version": "0.1.0",
  "description": "A fresh Electron desktop app.",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "update:deps": "ncu -u && npm install",
    "test": "npm run check && node --test",
    "build:mac": "electron-builder --mac",
    "build:mac:dir": "electron-builder --mac dir",
    "open:mac": "npm run build:mac:dir && open dist/mac-arm64/Leena.app"
  },
  "keywords": [
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "build": {
    "appId": "com.leena.app",
    "productName": "Leena",
    "asar": true,
    "npmRebuild": true,
    "asarUnpack": [
      "**/node_modules/@nut-tree-fork/**"
    ],
    "files": [
      "src/**/*",
      "build/tray/**",
      "src/renderer/assets/**",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        "dmg",
        "zip"
      ],
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "timestamp": null,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Leena needs microphone access for realtime voice input.",
        "NSScreenCaptureDescription": "Leena needs screen recording access for screenshots and screen analysis."
      }
    },
    "publish": {
      "provider": "github",
      "owner": "yasmineseidu",
      "repo": "leena"
    }
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "npm-check-updates": "^22.2.1"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@nut-tree-fork/nut-js": "^4.2.6",
    "electron-updater": "^6.8.3",
    "playwright": "^1.60.0"
  }
}
